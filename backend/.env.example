# Copy to backend/.env for local development (never commit real keys).
# Vercel AI Gateway (OpenAI-compatible): https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=your-gateway-key-here
# Optional override (default https://ai-gateway.vercel.sh/v1)
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# Default when the UI sends no explicit model id (same as browser default gpt-5.4).
AI_DEFAULT_MODEL=gpt-5.4

# POST /api/compare-resume-job-match uses the same selected gateway model as the rest of the home page.

# Comma-separated origins allowed by CORS (Vite default below).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: remote LaTeX→PDF HTTP service (POST multipart field "latex").
# Leave empty: Docker uses pdflatex inside the pandoc/latex-based image;
# local dev uses pdflatex on your PATH (MacTeX / TeX Live / MiKTeX).
# PDF_REMOTE_COMPILE_URL=

# Optional: MongoDB apply journal (History). Leave unset or empty to disable.
# Example: mongodb://localhost:27017/ai_assisted_apply
# MONGODB_URI=
