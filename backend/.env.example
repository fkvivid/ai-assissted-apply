# Copy to backend/.env for local development (never commit real keys).
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Comma-separated origins allowed by CORS (Vite default below).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: remote LaTeX→PDF HTTP service (POST multipart field "latex").
# Leave empty: Docker uses pdflatex inside the pandoc/latex-based image;
# local dev uses pdflatex on your PATH (MacTeX / TeX Live / MiKTeX).
# PDF_REMOTE_COMPILE_URL=

# Optional: MongoDB apply journal (History). Leave unset or empty to disable.
# Example: mongodb://localhost:27017/ai_assisted_apply
# MONGODB_URI=